{
    "root": "Diploma_Project/",
    "ignore": [
        ".git",
        ".idea",
        ".vscode",
        "__pycache__",
        "env",
        "venv",
        "archive",
        "data",
        "models"
    ],

    "folders": {
        "src": "src/",
        "src_deployment": "src/deployment/",
        "src_features": "src/features/",
        "src_models": "src/models/",
        "src_utils": "src/utils/",

        "scripts": "scripts/",
        "configs": "configs/",
        "maintenance": "maintenance/",

        "reports": "reports/",
        "reports_figures": "reports/figures/",
        "reports_stage2": "reports/figures/stage2/",
        "reports_stage3": "reports/figures/stage3/",
        "reports_stage4": "reports/figures/stage4/",
        "reports_stage5": "reports/figures/stage5/",
        "reports_stage8": "reports/figures/stage8/",
        "reports_stage10": "reports/figures/stage10/"
    },

    "stages": {
        "stage1": {
            "suffix": "_data",
            "name": "Data Loading",
            "input": ["raw CSV files"],
            "input_path": "data/raw/",
            "output": ["loaded DataFrames"],
            "output_path": "data/stage_outputs/stage1_data/",
            "output_format": ".pkl",
            "purpose": "Load raw data",
            "description": "Load CSVs into DataFrames",
            "variants": ["full"],
            "active_variant": "full"
        },

        "stage2": {
            "suffix": "_eda",
            "name": "Univariate EDA",
            "input": ["stage1 DataFrames"],
            "input_path": "data/stage_outputs/stage1_data/",
            "output": ["EDA dicts", "plots"],
            "output_path": "data/stage_outputs/stage2_eda/",
            "output_format": [".pkl", ".json", ".png"],
            "purpose": "Explore distributions",
            "description": "Univariate EDA and feature screening",
            "variants": ["eda_v1"],
            "active_variant": "eda_v1"
        },

        "stage3": {
            "suffix": "_baseline",
            "name": "Baseline Modeling",
            "input": ["EDA features"],
            "input_path": "data/stage_outputs/stage2_eda/",
            "output": ["baseline model", "feature importance"],
            "output_path": "data/stage_outputs/stage3_baseline/",
            "output_format": [".pkl", ".csv"],
            "purpose": "Establish baseline",
            "description": "Train baseline LightGBM",
            "variants": ["baseline_default"],
            "active_variant": "baseline_default"
        },

        "stage4": {
            "suffix": "_bivariate",
            "name": "Bivariate EDA",
            "input": ["top features"],
            "input_path": "data/stage_outputs/stage3_baseline/",
            "output": ["bivariate plots", "MI scores"],
            "output_path": "data/stage_outputs/stage4_bivariate/",
            "output_format": [".png", ".csv"],
            "purpose": "TARGET relationships",
            "description": "Numeric & categorical bivariate analysis",
            "variants": ["bivariate_v1"],
            "active_variant": "bivariate_v1"
        },

        "stage5": {
            "suffix": "_multivariate",
            "name": "Multivariate EDA",
            "input": ["top features"],
            "input_path": "data/stage_outputs/stage4_bivariate/",
            "output": ["interaction plots"],
            "output_path": "data/stage_outputs/stage5_multivariate/",
            "output_format": [".png", ".csv"],
            "purpose": "Feature interactions",
            "description": "SHAP interactions, PDP",
            "variants": ["multi_v1"],
            "active_variant": "multi_v1"
        },

        "stage6": {
            "suffix": "_features",
            "name": "Feature Engineering",
            "input": ["raw + secondary tables"],
            "input_path": "data/stage_outputs/stage1_data/",
            "output": ["engineered dataset"],
            "output_path": "data/stage_outputs/stage6_features/",
            "output_format": ".parquet",
            "purpose": "Create final dataset",
            "description": "Aggregations, encodings, ratios",
            "variants": ["fe_full"],
            "active_variant": "fe_full"
        },

        "stage7": {
            "suffix": "_models",
            "name": "Advanced Modeling",
            "input": ["engineered dataset"],
            "input_path": "data/stage_outputs/stage6_features/",
            "output": ["models", "CV results"],
            "output_path": "data/stage_outputs/stage7_models/",
            "output_format": [".pkl", ".json"],
            "purpose": "Build strong models",
            "description": "LGBM tuned, CatBoost, stacking",
            "variants": ["lgbm_v1", "stack_v1"],
            "active_variant": "lgbm_v1"
        },

        "stage8": {
            "suffix": "_optimization",
            "name": "Model Optimization",
            "input": ["stage7 models"],
            "input_path": "data/stage_outputs/stage7_models/",
            "output": ["optimized models", "Optuna studies"],
            "output_path": "data/stage_outputs/stage8_optimization/",
            "output_format": [".pkl", ".json"],
            "purpose": "Optimize ensemble",
            "description": "Optuna tuning for meta‑model",
            "variants": ["optuna_v1"],
            "active_variant": "optuna_v1"
        },

        "stage9": {
            "suffix": "_interpretation",
            "name": "Interpretation",
            "input": ["optimized model + dataset"],
            "input_path": "data/stage_outputs/stage8_optimization/",
            "output": ["SHAP plots", "reports"],
            "output_path": "data/stage_outputs/stage9_interpretation/",
            "output_format": [".png", ".csv"],
            "purpose": "Explain model",
            "description": "SHAP, PDP, interactions",
            "variants": ["interp_v1"],
            "active_variant": "interp_v1"
        },

        "stage10": {
            "suffix": "_inference",
            "name": "Final Inference Pipeline",
            "input": [
                "raw test data",
                "FE pipeline",
                "optimized model"
            ],
            "input_path": [
                "data/raw/",
                "data/stage_outputs/stage6_features/",
                "data/stage_outputs/stage8_optimization/"
            ],
            "output": ["submission file"],
            "output_path": "data/stage_outputs/stage10_submission/",
            "output_format": ".csv",
            "purpose": "Produce predictions",
            "description": "Apply FE → optimized model → submission",
            "variants": ["sub_v1"],
            "active_variant": "sub_v1"
        }
    }
}
